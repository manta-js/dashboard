{
  "name": "@mantajs/dashboard",
  "version": "0.2.0",
  "description": "B2B Admin Dashboard for Medusa - Fork of @medusajs/dashboard",
  "license": "MIT",
  "author": {
    "name": "Olivier Belaud",
    "url": "https://github.com/OlivierBelaud"
  },
  "homepage": "https://github.com/manta-js/dashboard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/manta-js/dashboard"
  },
  "bugs": {
    "url": "https://github.com/manta-js/dashboard/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "yarn@1.22.22",
  "keywords": [
    "medusa",
    "dashboard",
    "admin",
    "b2b",
    "ecommerce",
    "vite-plugin"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && tsup --config tsup.vite-plugin.config.ts",
    "build:preview": "vite build --outDir preview-dist --emptyOutDir",
    "preview": "vite preview",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:package": "node ./scripts/verify-package-contract.mjs",
    "test:consumer": "node ./scripts/verify-packed-consumer.mjs",
    "verify": "yarn typecheck && yarn test && yarn build && yarn test:package && yarn test:consumer && yarn i18n:validate && yarn build:preview && yarn audit --groups dependencies --level moderate",
    "i18n:validate": "node ./scripts/i18n/validate-translation.js en.json",
    "i18n:schema": "node ./scripts/i18n/generate-schema.js"
  },
  "main": "dist/app.js",
  "module": "dist/app.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/app.mjs",
      "require": "./dist/app.js"
    },
    "./css": {
      "import": "./dist/app.css",
      "require": "./dist/app.css"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.mjs",
      "require": "./dist/vite-plugin/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.mjs",
      "require": "./dist/components.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js"
    },
    "./root": "./",
    "./package.json": "./package.json"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "src",
    "dist"
  ],
  "dependencies": {
    "@ariakit/react": "^0.4.15",
    "@babel/runtime": "^7.26.10",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/error-message": "^2.0.1",
    "@hookform/resolvers": "3.4.2",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/js-sdk": "2.16.0",
    "@medusajs/ui": "4.1.16",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dismissable-layer": "1.1.4",
    "@tanstack/react-query": "5.64.2",
    "@tanstack/react-table": "8.20.5",
    "@tanstack/react-virtual": "^3.8.3",
    "@uiw/react-json-view": "^2.0.0-alpha.17",
    "cmdk": "^0.2.0",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "^3.6.0",
    "i18next": "23.7.11",
    "i18next-browser-languagedetector": "7.2.0",
    "i18next-http-backend": "3.0.5",
    "lodash.debounce": "^4.0.8",
    "lodash.isequal": "^4.5.0",
    "match-sorter": "^6.3.4",
    "motion": "^11.15.0",
    "qrcode": "^1.5.4",
    "qs": "^6.12.1",
    "radix-ui": "1.1.2",
    "react": "^18.3.1",
    "react-country-flag": "^3.1.0",
    "react-currency-input-field": "^3.6.11",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "7.49.1",
    "react-i18next": "13.5.0",
    "react-jwt": "^1.2.0",
    "react-router-dom": "6.30.4",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/admin-vite-plugin": "2.16.0",
    "@medusajs/types": "2.16.0",
    "@medusajs/ui-preset": "2.16.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash.debounce": "4.0.9",
    "@types/lodash.isequal": "4.5.8",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^4.0.0",
    "ajv": "8.17.1",
    "autoprefixer": "^10.4.16",
    "jsdom": "26.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsup": "^8.0.0",
    "typescript": "5.9.3",
    "vite": "^5.4.14",
    "vite-plugin-inspect": "^0.8.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "vite": "^5.4.14"
  }
}
